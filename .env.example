# LLM 配置
LLM_PROVIDER=zhipu

# API 配置（替换为你的 API Key）
GLM_API_KEY=your-api-key-here
GLM_API_BASE=your-api-base-here

# LLM 参数
LLM_MODEL=glm-4.5-air
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=20000

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/ops_agent.log

# Agent 配置
MAX_ITERATIONS=15
TIMEOUT=300
MAX_ERROR_LINES=5
PARALLEL_ANALYSIS=false

# 输出配置
OUTPUT_DIR=output
